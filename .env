# ─────────────────────────────────────────────────────────────
# SpeedCam Guard 프록시 서버 환경 변수
# 이 파일을 .env 로 복사한 후 값을 채워주세요.
# cp .env.example .env
# ─────────────────────────────────────────────────────────────

# 포트 번호 (기본: 3001)
PORT=3001

# 공공데이터포털 서비스키 (Decoding 키)
# https://www.data.go.kr/data/15028200/openapi.do 에서 신청
# 여기에 키를 넣으면 클라이언트에서 키를 노출하지 않아도 됩니다.
DATA_GO_KR_KEY=1b3b2c532fd0de5dcbd49c558b1e658a234d7d07bba1189bb218373e366cb2e9

# 허용 클라이언트 도메인 (기본: 모두 허용)
# 프로덕션에서는 실제 도메인으로 변경하세요.
# CLIENT_ORIGIN=https://yourdomain.com
